# Mistral API key (mandatory)
MISTRAL_API_KEY=

# Multi-user (recommandé en prod) — format : user1:password1,user2:password2,...
# Chaque user voit uniquement ses propres conversations.
BASIC_AUTH_USERS=alice:changeme,bob:changeme,charlie:changeme

# Single-user fallback (pour dev local). Ignoré si BASIC_AUTH_USERS est défini.
# BASIC_AUTH_USER=famille
# BASIC_AUTH_PASSWORD=
